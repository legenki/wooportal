{
  "name": "wooportal-extension",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:background && npm run build:popup && npm run build:options",
    "build:background": "vite build --config vite.config.background.ts",
    "build:popup": "vite build --config vite.config.popup.ts",
    "build:options": "vite build --config vite.config.options.ts",
    "dev:popup": "vite build --config vite.config.popup.ts --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "d3-geo": "^3.1.1",
    "topojson-client": "^3.1.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/d3-geo": "^3.1.0",
    "@types/topojson-client": "^3.1.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.12",
    "vitest": "^1.6.0"
  },
  "allowScripts": {
    "esbuild@0.21.5": true,
    "fsevents@2.3.3": true
  }
}
